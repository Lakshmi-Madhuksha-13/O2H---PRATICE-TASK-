{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Backend (Laravel)",
      "type": "shell",
      "command": "php artisan serve",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "servers"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Frontend (Vite)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "servers"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Taskora Project",
      "dependsOn": [
        "Run Backend (Laravel)",
        "Run Frontend (Vite)"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
