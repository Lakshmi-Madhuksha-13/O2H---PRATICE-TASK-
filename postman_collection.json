            },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/tasks?page=1&per_page=10&status=Pending&priority=High&search=Auth",
              "host": ["{{base_url}}"],
              "path": ["tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "10" },
                { "key": "status", "value": "Pending" },
                { "key": "priority", "value": "High" },
                { "key": "search", "value": "Auth" }
